{
  "manifest_version": 3,
  "name": "Fruit Tab Cards",
  "description": "以水果卡片视图管理 Chrome 标签页、标签组、重复标签和建议关闭项。",
  "version": "1.0.0",
  "icons": {
    "16": "assets/app-icon-16.png",
    "32": "assets/app-icon-32.png",
    "48": "assets/app-icon-48.png",
    "128": "assets/app-icon-128.png"
  },
  "action": {
    "default_title": "Fruit Tab Cards",
    "default_icon": {
      "16": "assets/app-icon-16.png",
      "32": "assets/app-icon-32.png",
      "48": "assets/app-icon-48.png",
      "128": "assets/app-icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "bookmarks",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
